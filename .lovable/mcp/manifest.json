{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "finese-ai-mcp",
      "version": "0.1.0",
      "title": "FINESE AI"
    },
    "tools": [
      {
        "name": "about_finese",
        "title": "About FINESE AI",
        "description": "Return a short description of FINESE AI, its capabilities, and the modes it supports.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "echo",
        "title": "Echo",
        "description": "Echo the input text back to the caller. Useful for verifying MCP connectivity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "description": "Text to echo back."
            }
          },
          "required": [
            "text"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_sample_datasets",
        "title": "List sample datasets",
        "description": "List the built-in public sample datasets available in FINESE AI (sales, HR, stock) with row counts, column names, and a small preview.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_sample_dataset",
        "title": "Get sample dataset",
        "description": "Return the full rows of a built-in public sample dataset (sales, hr, or stock).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "enum": [
                "sales",
                "hr",
                "stock"
              ],
              "description": "Which sample dataset to fetch."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500,
              "description": "Optional max rows to return."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_prompt_sectors",
        "title": "List prompt sectors",
        "description": "List the public prompt library sectors (Data Analysis, Data Science, Data Engineering, MLOps, etc.) with prompt counts.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_sample_prompts",
        "title": "Get sample prompts",
        "description": "Return the full list of curated sample prompts for a given sector (analysis, science, engineering, mlops, other).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "sectorId": {
              "type": "string",
              "description": "Sector id from list_prompt_sectors."
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200,
              "description": "Optional max prompts to return."
            }
          },
          "required": [
            "sectorId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
